# OIF Aggregator API endpoint
VITE_API_BASE_URL=http://localhost:4000

# Optional: Mainnet-specific RPC endpoint used by wallet and approval checks
# For production, prefer a dedicated provider with higher rate limits.
VITE_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Optional: Chain-specific overrides for custom or unsupported chains
# VITE_RPC_URL_42161=https://arb1.arbitrum.io/rpc
#
# Optional: Generic fallback for chains not listed in the app RPC map.
# Use a multi-chain RPC proxy here; otherwise leave unset to fail loudly.
# VITE_DEFAULT_RPC=https://your-multichain-rpc.example

# Optional: WalletConnect project ID (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here
