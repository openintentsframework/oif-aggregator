# OIF Aggregator API endpoint
VITE_API_BASE_URL=http://localhost:4000

# Optional: Fallback RPC endpoint for unsupported chains
VITE_RPC_URL=https://ethereum-rpc.publicnode.com

# Optional: Mainnet-specific RPC endpoint used by wallet and approval checks
VITE_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Optional: WalletConnect project ID (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here
